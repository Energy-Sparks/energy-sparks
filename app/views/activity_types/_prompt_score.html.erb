<%= simple_form_for :activity_type, url: for_school_activity_type_path(activity_type), method: :get do |f| %>
  <%= render PromptComponent.new(icon: 'tasks', theme: :dark, classes: 'mb-4') do |prompt| %>
    <% prompt.with_content_action do |c| %>
        <% c.with_body { t('activity_types.show.complete_this_activity_html', count: activity_type.score) } %>
        <% c.with_action do %>
          <%= link_to t('activity_types.show.record_this_activity'),
                      new_school_activity_path(school,
                                               activity_type_id: activity_type.id),
                      class: 'btn btn-primary text-nowrap' %>
        <% end %>
    <% end %>
  <% end %>
<% end %>
