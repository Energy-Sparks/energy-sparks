<%= simple_form_for :activity_type, url: for_school_activity_type_path(activity_type), method: :get do |f| %>
  <%= render PromptComponent.new(icon: 'tasks', status: :none, classes: 'mb-4') do |prompt| %>
    <% prompt.with_title { t('activity_types.show.complete_this_activity_for_group_html', count: activity_type.score) } %>
    <% prompt.with_content_action do |c| %>
        <% c.with_body do %>
          <%= select_tag :school_id, options_from_collection_for_select(schools, :id, :name),
                         include_blank: t('activity_types.show.select_school'),
                         class: 'form-select select2 must-select disable-tooltip' %>
        <% end %>
        <% c.with_action do %>
          <%= f.submit t('activity_types.show.record_this_activity'),
                       class: 'btn btn-primary',
                       'data-bs-toggle': 'tooltip',
                       'data-bs-placement': 'bottom',
                       title: t('activity_types.show.select_school') %>
        <% end %>
    <% end %>
  <% end %>
<% end %>
