<h1>Lagging meters</h1>
<p>The following data_sources have a high percentage of lagging meters according to their alert threshold.<p>
<p>See the data_source___ for further information.</p>
<table>
    <thead>
        <tr>
            <th>Data Source Name</th>
            <th>Active meters</th>
            <th>Lagging Meters</th>
            <th>Percentage of lagging meters</th>
            <th>Alert Percentage Threshold</th>
        </tr>
    </thead>
    <tbody>
        <% @lagging.each do |data_source| %>
            <tr>
                <td><%= data_source.name %></td>
                <td><%= data_source.meters.all ? data_source.meters.active_for_active_schools : 'None' %></td>
                <td><%= data_source.meters.all ? data_source.meters.with_stale_readings : 'None' %></td>
                <td><%= data_source.percentage_of_lagging_meters %>%</td>
                <td><%= data_source.alert_percentage_threshold || 0 %>%</td>
            </tr>
        <% end %>
    </tbody>
</table>
