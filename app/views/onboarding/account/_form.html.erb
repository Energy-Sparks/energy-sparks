<%= f.input :name, label: t('onboarding.account.your_name') %>
<%= f.input :email %>
<%= f.input :password %>
<%= f.input :password_confirmation %>
<%= f.input :staff_role_id, required: true, collection: StaffRole.order(:title),
                            label_method: :translated_title, hint: t('onboarding.account.role_hint') %>

<%= render 'users/preferred_locale', user:, f: f %>

<div class="row mt-4">
  <div class="col-md-12">
    <%= label_tag :school, t('mailchimp_signups.mailchimp_form.email_preferences') %>
  </div>
</div>
<%= render 'users/emails/mailchimp_interest_fields',
           email_types: email_types,
           interests: interests %>
