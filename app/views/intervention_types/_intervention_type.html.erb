<div class="row mt-5">
  <div class="col-sm-2">
    <%= link_to intervention_type_path(intervention_type) do %>
      <%= render 'intervention_types/image', intervention_type: intervention_type,
                                             css_class: 'activity-card-img-thumbnail' %>
    <% end %>
  </div>
  <div class="col-sm-10">
    <h4>
      <%= link_to intervention_type.name, intervention_type_path(intervention_type) %>
    </h4>
    <p>
      <%= intervention_type.summary %>
    </p>
    <% if school.present? && intervention_type.actions_for_school(school).any? %>
      <%= render 'shared/tasks/prompts/previous_records',
                 recordings: intervention_type.actions_for_school(school),
                 school: school, resource_type: :intervention %>
    <% else %>
      <%= render 'intervention_types/intervention_type_points', intervention_type: intervention_type %>
    <% end %>
  </div>
</div>
