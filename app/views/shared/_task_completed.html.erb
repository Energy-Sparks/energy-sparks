<% content_for :page_title, t("tasks.completed.#{task_type}.page_title", school: school.name) %>

<% content_for :header do %>
<h1>
  <%= t('tasks.completed.congratulations') %>
  <% if recording.points.to_i.positive? %>
    <% if recording.academic_year.future? %>
      <%= t('tasks.completed.points_with_academic_year',
            points: recording.points,
            academic_year: recording.academic_year.title) %>
      <% else %>
        <%= t('tasks.completed.points', points: recording.points) %>
      <% end %>
  <% else %>
    <%= t("tasks.completed.#{task_type}.no_points") %>
  <% end %>
</h1>
<% end %>
<%# recording.programmes_completed_todos.completed.recently_ended.each do |programme| %>
<% school.programmes.take(1).each do |programme| %>
  <%= render PromptComponent.new(
        image: programme.programme_type.t_attached_or_default(
          :image, placeholder: 'placeholder300x200.png'
        ),
        status: :positive, style: :compact, classes: 'mt-2'
      ) do |prompt| %>
    <% prompt.with_link do %>
      <%= link_to t('common.labels.view'),
                  programme_type_path(programme.programme_type) %>
    <% end %>
    <p>
      <%= t('schools.prompts.completed_programme.message_html',
            title: programme.title,
            count: programme.points_for_completion) %>
    </p>
  <% end %>

<% end %>

<h3><%= t('tasks.completed.what_next') %></h3>

<%= render 'schools/prompts/share', recording:, task_type:, style: :compact %>
<%= render 'schools/prompts/complete_programme',
           programmes: school.programmes.active.started.order(started_on: :desc),
           style: :compact %>
<%= render 'schools/prompts/join_programme', school: school, style: :compact %>
<%= render 'schools/prompts/audit', audit: Audits::AuditService.new(school).last_audit, style: :compact %>
<%= render 'schools/prompts/recommended', scope: recommendations_scope_for(task_type), icon: true, style: :compact %>

<%= render Scoreboards::SchoolSummaryComponent.new(podium: current_school_podium, title: '') %>
