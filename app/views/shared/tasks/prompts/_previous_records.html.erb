<% label_key = resource_type == :intervention ? :action : :activity %>
<% path_helper = "school_#{resource_type}_path" %>
<% recordings = recordings.by_date(:asc) %>

<%= render PromptComponent.new(icon: 'circle-check', status: :none, classes: 'mb-4') do |prompt| %>
  <%= t('activities.previous_records.previously_completed', label: t("common.labels.#{label_key}")) %>
  <strong>
    <%= link_to human_counts(recordings).to_s, school_timeline_path(school) %>
  </strong>
  <% if recordings.count > 1 %>
    <%= t('activities.previous_records.completed_most_recently_on') %>
  <% else %>
    <%= t('activities.previous_records.completed_on') %>
  <% end %>
  <strong>
    <%= link_to nice_dates(recordings.last.happened_on).to_s, public_send(path_helper, school, recordings.last) %>
  </strong>
<% end %>
