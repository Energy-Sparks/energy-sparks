<%= render PromptComponent.new(icon: 'tasks', classes: 'mb-4 theme theme-dark') do |prompt| %>
  <% prompt.with_title { t('activities.prompt_login_to_record.are_you_an_energy_sparks_user') } %>
  <% prompt.with_content_action do |c| %>
      <% c.with_body do %>
        <%= t('activities.prompt_login_to_record.sign_in_html', label: label, count: score) %>        <% end %>
      <% c.with_action do %>
        <%= link_to t('activities.prompt_login_to_record.sign_in_to_record_html', label: label),
                    sign_in_and_redirect_path(url: return_path), class: 'btn btn-primary text-nowrap' %>
      <% end %>
  <% end %>
<% end %>
