<%= render 'schools/school_page_with_navigation', school: @school,
                                                  page_title: "#{@school.name} Licences" do %>

  <div class="row">
    <div class="col">
      <p>
        <%= link_to 'New contract',
                    choose_admin_commercial_contracts_path(contract_holder_type: @school.class,
                                                           contract_holder_id: @school.id),
                    class: 'btn btn-primary btn-sm' %>
      </p>
    </div>
  </div>

  <div class="row">
    <div class="col">
      <h3>Licences</h3>
      <p>The following table lists all current, historical and future licences held by <%= @school.name %>.</p>
    </div>
  </div>

  <div class="row mt-2">
    <div class="col">
      <%= render Commercial::LicencesComponent.new(licences: @licences,
                                                   show_contract_holder: false) %>
    </div>
  </div>
<% end %>
