<% if @dashboard_user %>
  <% content_for :title do %>
    <%= "Activities for #{@dashboard_user.display_name}" %>
  <% end %>
  <p>
    <%= link_to 'Full Activities Report', admin_reports_activities_path, class: 'btn' %>
  </p>
  <p>
    A list of all activities by <%= @dashboard_user.display_name %>'s schools in the last 12 months
    (since <%= nice_dates(1.year.ago) %>).
  </p>
<% else %>
  <% content_for :page_title, 'Recently recorded activities' %>

<div class="d-flex justify-content-between align-items-center">
  <h1>Recently recorded activities</h1>

  <div>
    <%= link_to 'Activity type overview', admin_reports_activity_types_path, class: 'btn btn-default' %>
    <%= link_to 'All reports', admin_reports_path, class: 'btn btn-default' %>
  </div>
</div>

<p>
  The following is a list of all activities by schools in the last 12 months (since <%= nice_dates(1.year.ago) %>).
</p>
<% end %>

<p>Activities with a <span class="text-success">Green link</span> are those where the school has
  provided a custom title. Others are shown as a <span class="text-muted">grey link</span> </p>
<p>

<p>
The <%= fa_icon('check-circle text-success') %> icon in the images column indicates that the activity includes
images provided by the user
</p>

<div class="clearfix bg-light py-2 px-2 my-2 border rounded">
  <%= form_tag admin_reports_activities_path, method: :get do |f| %>
    <div class="d-flex justify-content-between align-items-center">
      <div class="">
        <span class="nowrap">
          <%= text_field_tag :search, params[:search], autocomplete: 'off',
                                                       placeholder: 'Search issues...',
                                                       width: 200,
                                                       class: '' %>
        </span>
        <span class="nowrap">
          <%= label_tag :admin, nil, class: 'small' %>
          <%= select_tag :admin,
                         options_from_collection_for_select(User.admins_by_name, :id, :display_name, params[:admin]),
                         include_blank: 'Any Admin User',
                         class: 'form-control-sm' %>
        </span>
      </div>
      <div class="d-flex justify-content-between">
        <%= submit_tag 'Filter', class: 'btn btn-sm' %>
        <% unless defined? no_csv %>
          <%= link_to 'CSV for below table',
                      url_for(
                        controller: controller_path,
                        action: :index,
                        only_path: true,
                        **params.permit(:school_group, :admin, :meter_type, :active).merge(format: :csv)
                      ),
                      class: 'ml-2 btn btn-sm' %>
          <% end %>
      </div>
    </div>
  <% end %>
</div>

<%= render 'shared/activities', activities: @activities %>
