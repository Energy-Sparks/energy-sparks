<% form = SimpleForm::FormBuilder.new(:contract, @contract, self, {}) %>
<% nested = render(
     Forms::Commercial::BulkLicenceEditorComponent.licence_row(
       form:, licence: @licence, exclude_fields: [:invoice_reference]
     )
   ) %>

var html = "<%= j nested %>";

document
  .getElementById("licence-rows")
  .insertAdjacentHTML("beforeend", html);

// Remove the missing-school row
document.getElementById("additional-school-<%= @school.id %>").remove()
