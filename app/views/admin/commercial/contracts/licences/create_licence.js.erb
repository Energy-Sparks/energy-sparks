<% form = SimpleForm::FormBuilder.new(:commercial_contract, @contract, self, {}) %>
<% nested = render(
    Forms::Commercial::BulkLicenceEditorComponent.licence_row(
      form:, licence: @licence, exclude_fields: [:invoice_reference]
    )
  ) %>

var html = "<%= j nested %>";

// Add in new content
var container = document.getElementById("licence-rows");
container.insertAdjacentHTML("afterbegin", html);

var newMainRow = document.getElementById("licence-<%= @licence.id %>-main-row");

initTempusDominus(newMainRow);

// Remove the row in the additional school table
document.getElementById("additional-school-<%= @school.id %>").remove()
