<%= render Admin::HeaderNavComponent.new do |header_nav| %>
  <% header_nav.with_header title: 'Raise New Invoice' %>
  <% header_nav.with_button 'Contract', admin_commercial_contract_path(@contract) %>
<% end %>

<p>
  The licences for the following schools are now ready for invoicing as part of the
  <%= link_to @contract.name, admin_commercial_contract_path(@contract) %> contract.
</p>

<h3>Review account code</h3>

<p>This contract is set to raise invoices using <strong><%= @contract.xero_account_code&.display_label %></strong></p>

<p><%= link_to 'Edit the contract ', edit_admin_commercial_contract_path(@contract) %> to change the code</p>

<h3>Review licence terms and schools status</h3>

<p>
Before continuining, check the licence details and school status below to ensure that we are ready to raise and
invoice for these schools.
</p>

<ul>
  <li>
    To adjust dates for the whole contract, please
    <%= link_to 'edit the contract ', edit_admin_commercial_contract_path(@contract) %>
  </li>
  <li>
    To quickly adjust the details for a number of licences then
    <%= link_to 'manage all licences', edit_admin_commercial_contract_licences_path(@contract) %>.
  </li>
  <li>
    To alter an individual licence, use the buttons below.
  </li>
</ul>

<p>
  To raise a new invoice for this contract, first select which schools should be included as part of the
  new invoice and then click 'Proceed'.
</p>

<%= simple_form_for :raise_invoice, url: new_admin_commercial_contract_invoice_path(@contract), method: 'GET' do |f| %>
  <table id="raise-invoice-table" class="table table-sorted table-sm">
    <thead>
      <tr>
        <th colspan="1"></th>
        <th colspan="1"></th>
        <th colspan="3" class="text-start">School</th>
        <th colspan="3" class="text-start">Licence</th>
        <th colspan="1"></th>
      </tr>
      <tr>
        <th class="no-sort">
          <%= check_box_tag 'check-all', false, false, { class: 'check-all-form' } %>
        </th>
        <th>Id</th>
        <th>School Group</th>
        <th>School</th>
        <th class="col-1">Data Status</th>
        <th class="col-1">Start date</th>
        <th class="col-1">End date</th>
        <th class="col-1">Price</th>
        <th class="col-1 no-sort">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @licences.each do |licence| %>
        <tr>
          <td class="">
              <%= check_box_tag 'licences[]',
                                licence.id,
                                false,
                                class: 'allow-submit',
                                id: "licence_#{licence.id}" %>
          </td>
          <td class="col-1">
            <%= link_to "##{licence.id}", admin_commercial_licence_path(licence) %>
          </td>
          <td>
            <%= if licence.school.school_group
                  link_to(licence.school.school_group.name, school_group_path(licence.school.school_group))
                end %>
          </td>
          <td>
            <%= link_to licence.school.name, school_path(licence.school) %>
          </td>
          <td class="col-1">
            <%= render Schools::UtilityStatusComponent.new(school: licence.school) %>
          </td>
          <td data-order="<%= licence.start_date.iso8601 %>">
            <%= licence.start_date.to_fs(:es_short) %>
          </td>
          <td data-order="<%= licence.end_date.iso8601 %>">
            <%= licence.end_date.to_fs(:es_short) %>
          </td>
          <td>
            <%= format_price(@prices[licence.school.id][:price].total) %>
          </td>
          <td>
            <%= link_to 'Edit', edit_admin_commercial_licence_path(licence),
                        class: 'btn btn-secondary btn-sm' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <%= f.submit 'Proceed', disabled: true, class: 'btn btn-primary' %>
<% end %>
