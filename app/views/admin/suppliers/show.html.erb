<%= render 'header', title: "#{@supplier.name} supplier" do %>
  <%= header_nav_link 'All suppliers', admin_suppliers_url %>
<% end %>

<%= render TabsComponent.new(classes: 'preserve-tab-link') do |component| %>
  <% component.with_tab(name: :issues,
                        label: label_count('Issues', @supplier.issues.issue.status_open.count)) do %>
    <% if @supplier.issues.any? %>
      <%= render 'admin/issues/issues_list', issues: @supplier.issues.by_priority_order,
                                             issueable_type: 'Supplier' %>
    <% else %>
      <div class="bg-light p-2">No issues for <%= @supplier.name %>.</div>
    <% end %>
    <div class='pt-3'><%= render 'admin/issues/issues_links', issueable: @supplier %></div>
  <% end %>

  <% component.with_tab(name: :meter_issues,
                        label: label_count('Meter issues', @supplier.active_meter_issues.issue.status_open.count)) do %>
    <% if @supplier.active_meter_issues.issue.any? %>
      <%= render 'admin/issues/issues_list', issues: @supplier.active_meter_issues.issue.status_open.by_priority_order,
                                             issuable_type: 'Supplier' %>
    <% else %>
      <div class="bg-light p-2">No meter issues for <%= @supplier.name %>.</div>
    <% end %>
    <div class='pt-3'><%= render 'admin/issues/issues_links', issueable: @supplier %></div>
  <% end %>
<% end %>
