<!-- Button trigger modal -->
<button type="button" class="<%= local_assigns[:class] %>" data-bs-toggle="modal"
    data-bs-target="#supplier_report-<%= supplier.id %>">
  <%= fa_icon('envelope') %> Email Supplier Report
</button>

<div class="modal fade" id="supplier_report-<%= supplier.id %>" tabindex="-1"
    aria-labelledby="supplier_report_label" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h4 class="modal-title" id="supplier_report_label">Email supplier report & csv</h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <%= form_tag deliver_admin_supplier_path(supplier), method: :post do %>
        <div class="modal-body">
          <div><strong>To: </strong>
            <span class="badge border rounded-pill text-dark border-secondary fw-normal">
              <%= current_user.email %>
            </span>
          </div>
          <div class="pb-2">
            <strong>Supplier: </strong><%= supplier.name %>
          </div>
        </div>
        <div class="modal-footer">
          <%= button_tag(type: 'submit', class: 'btn btn-secondary btn-sm',
                         data: {
                           confirm: "Are you sure you want to send the supplier report to #{current_user.email}?"
                         }) do %>
            <%= fa_icon('envelope') %> Email Supplier Report
          <% end %>
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
        </div>
      <% end %>
    </div>
  </div>
</div>
