<% if installation.persisted? %>
  <h3>Inverters</h3>
  <h4>Unassigned</h4>
  <table class="table">
    <thead>
      <tr>
        <th>Meter Name</th>
        <th>Meter serial</th>
        <th>Pseudo MPAN</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% (installation.inverter_detail_list || []).each do |inverter| %>
        <% next if installation.meters.pluck(:meter_serial_number).include?(inverter['sn']) %>
        <tr>
          <td><%= [inverter['stationName'], inverter['name']].compact.join(' / ') %></td>
          <td><%= inverter['sn'] %></td>
          <td>-</td>
          <td><%= button_tag('Assign', name: :assign, value: inverter['sn'], class: 'btn btn-primary') %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <h4>Assigned</h4>
  <table class="table">
    <thead>
      <tr>
        <th>Meter Name</th>
        <th>Meter serial</th>
        <th>Pseudo MPAN</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% installation.meters.where(school:).order(:name).each do |meter| %>
        <tr>
          <td><%= meter.name %></td>
          <td><%= meter.meter_serial_number %></td>
          <td><%= link_to meter.mpan_mprn, school_meter_path(meter.school_id, meter.id) %></td>
          <td><%= button_tag('Unassign', name: :unassign, value: meter.id, class: 'btn btn-primary') %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <div class="actions">
    <%= link_to 'Back', school_solar_feeds_configuration_index_path(school), class: 'btn' %>
  </div>
  <div class="other-actions">
    <%= link_to 'Update Inverter List', check_school_solis_cloud_installation_path(school, installation),
                method: :post, class: 'btn btn-primary mb-4' %>
  </div>
<% else %>
  <% options = SolisCloudInstallation.where.not(id: school.solis_cloud_installations).map do |installation|
       name = "API ID: #{installation.api_id}, Stations: " \
              "#{installation.inverter_detail_list.map { |d| d['stationName'] }.uniq.join(', ')}"
       [name, installation.id]
     end %>
  <%= render 'existing', options: %>
<% end %>
<%= form.input :api_id, as: :string, hint: 'The Solis Cloud API Key' %>
<%= form.input :api_secret, as: :string, hint: 'The Solid Cloud API Secret' %>
