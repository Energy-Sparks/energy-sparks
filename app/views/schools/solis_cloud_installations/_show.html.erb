<% if installation.inverter_detail_list.present? %>
  <h2>Cached site information</h2>
  <p>
    The following is a summary of the site description. It was last refreshed on
    <%= nice_date_times(installation.updated_at) %>. Run Check API on the previous page to update this
    cached copy.
  </p>
  <% installation.inverter_detail_list.each do |inverter| %>
    <h3>Inverter <%= inverter['id'] %></h3>
    <%= render 'key_value_table', pairs: inverter %>
  <% end %>
<% else %>
  <p>There is no cached copy of the site metadata</p>
<% end %>
