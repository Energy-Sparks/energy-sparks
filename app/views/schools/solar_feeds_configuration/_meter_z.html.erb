<% if school.meter_z_installations.any? %>
  <table class="table table-sm">
    <thead>
      <tr>
        <th>API Key</th>
        <th>Last updated</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% school.meter_z_installations.each do |installation| %>
        <tr>
          <td><%= link_to(installation.api_key, school_meter_z_installation_path(school, installation)) %></td>
          <td><%= nice_date_times(installation.updated_at) %></td>
          <td><%= render 'actions', installation:, school:,
                                    id_prefix: Schools::MeterZInstallationsController::ID_PREFIX %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>This school has no <%= Schools::MeterZInstallationsController::NAME %> sites</p>
<% end %>

<p><%= link_to "New #{Schools::MeterZInstallationsController::NAME} API feed",
               new_school_meter_z_installation_path, class: 'btn' %></p>
