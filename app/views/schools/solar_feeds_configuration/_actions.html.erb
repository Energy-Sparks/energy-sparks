<%= link_to 'Edit', polymorphic_path([:edit, school, installation]), class: 'btn btn-sm' %>
<%= link_to 'Delete', polymorphic_path([school, installation]),
            method: :delete,
            data: { confirm: 'Are you sure? This will delete the meter' },
            class: 'btn btn-sm btn-danger' %>
<%= link_to safe_join([fa_icon('circle-question'), ' Check API']),
            polymorphic_path([:check, school, installation]),
            id: "#{id_prefix}-#{installation.id}-test", method: :post, remote: true,
            class: 'btn btn-sm check-button' %>
<%= form_tag polymorphic_path([:submit_job, school, installation]), method: :post do %>
  <%= button_tag(type: 'submit', id: "#{id_prefix}-#{installation.id}-run-load", class: 'btn btn-sm') do %>
    <%= fa_icon('upload') %> Run Loader
  <% end %>
<% end %>
