<% i18n_scope = 'school_groups.impact.overview' %>

<%= render Layout::Cards::SectionHeaderComponent.new(
      id: 'overview-header'
    ) do |section_header| %>
  <%= section_header.with_header title: t('title', scope: i18n_scope) %>
  <%= section_header.with_description { t('description', scope: i18n_scope) } %>
<% end %>

<%= render Layout::GridComponent.new(id: 'overview-cards',
                                     cols: 4, classes: 'mb-4',
                                     cell_classes: 'mb-4',
                                     component_classes: 'theme theme-dark') do |grid| %>
  <% grid.with_stats_card do |card| %>
    <%= card.with_header title: t('cards.schools.title', scope: i18n_scope) %>
    <%= card.with_figure number_with_delimiter(impact_report.visible_schools_count) %>
    <%= card.with_subtext do
          t('cards.schools.subtext', scope: i18n_scope,
                                     count: impact_report.data_visible_schools_count)
        end %>
  <% end %>

  <% grid.with_stats_card do |card| %>
    <%= card.with_header title: t('cards.users.title', scope: i18n_scope) %>
    <%= card.with_figure number_with_delimiter(impact_report.overview.users) %>
    <%= card.with_subtext do
          t('cards.users.subtext', scope: i18n_scope,
                                   count: impact_report.overview.users_logged_in_recently)
        end %>
  <% end %>

  <% grid.with_stats_card do |card| %>
    <%= card.with_header title: t('cards.pupils.title', scope: i18n_scope) %>
    <%= card.with_figure number_with_delimiter(impact_report.overview.pupils) %>
    <%= card.with_subtext { t('cards.pupils.subtext', scope: i18n_scope) } %>
  <% end %>

  <% grid.with_stats_card(if: false) do |card| %>
    <%= card.with_header title: t('cards.funded_places.title', scope: i18n_scope) %>
    <%= card.with_figure format_unit(impact_report.overview.funded_places_value, :£) %>
    <%= card.with_subtext do
          t('cards.funded_places.subtext', scope: i18n_scope, count: impact_report.overview.funded_places)
        end %>
    <%= card.with_placeholder %>
  <% end %>

  <%= show_enrolling = impact_report.overview.enrolling_schools > impact_report.overview.enrolled_schools %>
  <% grid.with_stats_card(if: show_enrolling) do |card| %>
    <%= card.with_header title: t('cards.enrolling_schools.title', scope: i18n_scope) %>
    <%= card.with_figure number_with_delimiter(impact_report.overview.enrolling_schools) %>
    <%= card.with_subtext do
          t('cards.enrolling_schools.subtext', scope: i18n_scope)
        end %>
  <% end %>

  <% grid.with_stats_card(if: !show_enrolling) do |card| %>
    <%= card.with_header title: t('cards.enrolled_schools.title', scope: i18n_scope) %>
    <%= card.with_figure number_with_delimiter(impact_report.overview.enrolled_schools) %>
    <%= card.with_subtext do
          t('cards.enrolled_schools.subtext', scope: i18n_scope)
        end %>
  <% end %>
<% end %>

<%= render Layout::CarouselComponent.new(id: 'overview-testimonials',
                                         show_markers: false,
                                         theme: :accent,
                                         classes: 'rounded-3 p-4 mb-4',
                                         bs5: bs5?,
                                         show_arrows: :side) do |carousel| %>
  <% Testimonial.all.active.shuffle.each do |testimonial| %>
    <%= carousel.with_testimonial_card(testimonial: testimonial) %>
  <% end %>
  <%= carousel.with_placeholder(
        'Fix carousel to work with bootstrap 5. Use testimonials for school group',
        label: 'Note'
      ) %>
<% end %>
