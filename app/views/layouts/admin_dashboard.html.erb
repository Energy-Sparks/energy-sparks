<% if content_for(:header_title) %>
  <% content_for :page_title, yield(:header_title) unless content_for(:page_title) %>
<% else %>
  <% content_for :page_title, 'Dashboards' %>
<% end %>

<%= content_for(:application) do %>
  <% if @admin %>
    <% content_for :header do %>
      <%= render(Layout::Cards::PageHeaderComponent.new(
                   title: content_for?(:header_title) ? yield(:header_title) : 'default title'
                 )) %>
    <% end %>
    <% content_for :page_nav do %>
      <%= render Navigation::AdminDashboardComponent.new(current_user: @admin) %>
    <% end %>
    <%= yield %>
  <% else %>
    <%= yield %>
  <% end %>
<% end %>
<%= render template: 'layouts/application' %>
