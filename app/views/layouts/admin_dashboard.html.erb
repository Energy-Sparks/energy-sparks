<% unless content_for?(:page_title) %>
  <% content_for :page_title, content_for?(:title) ? yield(:title) : 'Admin Dashboard' %>
<% end %>

<% content_for :header do %>
  <%= render(Layout::Cards::PageHeaderComponent.new(
               title: content_for?(:title) ? yield(:title) : 'Admin Dashboard'
             )) %>
<% end %>

<% if @dashboard_user %>
  <% content_for :page_nav do %>
    <%= render Navigation::AdminDashboardComponent.new(current_user: @dashboard_user) %>
  <% end %>
<% end %>

<%= render template: 'layouts/application' %>
