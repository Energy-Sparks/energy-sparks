<%= content_for(:page) do %>
  <div class="container-fluid <%= @audience || :adult %> pb-2">
    <div class="container">
      <%= render 'admin/shared/breadcrumbs' %>
      <%= render(Layout::Cards::PageHeaderComponent.new(
                   title: content_for?(:header_title) ? yield(:header_title) : 'default title'
                 )) %>
    </div>
  </div>
  <div class="application <%= container_class %>">
    <% if @admin %>
      <div class="row mt-2">
        <div id="page-navigation" class="col-md-3 col-lg-3 col-xl-2">
          <%= render Navigation::AdminDashboardComponent.new(current_user: @admin) %>
        </div>
      </div>
    <% else %>
      <%= yield %>
    <% end %>
  </div>
<% end %>
<%= render template: 'layouts/page' %>
