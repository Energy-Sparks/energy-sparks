<% content_for :header do %>
  <%= render Admin::HeaderNavComponent.new do |header_nav| %>
    <% header_nav.with_header title: content_for?(:title) ? yield(:title) : 'Admin Dashboard' %>
  <% end %>
<% end %>

<% if @dashboard_user %>
  <% content_for :page_nav do %>
    <%= render Navigation::AdminDashboardComponent.new(current_user: @dashboard_user) %>
  <% end %>
<% end %>

<%= render template: 'layouts/application' %>
