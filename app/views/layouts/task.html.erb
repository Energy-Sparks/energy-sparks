<%= content_for(:page) do %>
  <% if content_for?(:header) %>
    <div class="container-fluid <%= @audience || :adult %> pb-2 mb-4">
      <div class="container">
        <%= render 'shared/page/breadcrumbs_and_flash' %>
        <%= yield :header %>
      </div>
    </div>
  <% end %>
  <div class='container'>
    <%= yield %>
  </div>
<% end %>
<%= render template: 'layouts/page' %>
