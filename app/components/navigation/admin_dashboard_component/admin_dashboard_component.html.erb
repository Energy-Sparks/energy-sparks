<%= render PageNavComponent.new name: 'Dashboard Home',
                                classes: classes,
                                icon: nil,
                                href: admin_dashboard_path(current_user),
                                options: { user: current_user, match_controller: true } do |c| %>
  <% classes = 'medium' %>

  <% c.with_section name: 'Manage Schools',
                    icon: 'school',
                    options: { match_controller: true } do |s| %>
    <% s.with_item(name: 'School Groups',
                   href: admin_dashboard_school_groups_path(current_user),
                   match_controller: true) %>
  <% end %>

  <% c.with_section name: 'My Schools',
                    options: { match_controller: true } do |s| %>
    <% my_schools_section.each do |item| %>
      <% s.with_item(name: item[:name],
                     href: item[:path],
                     match_controller: true) %>
    <% end %>
  <% end %>
<% end %>
