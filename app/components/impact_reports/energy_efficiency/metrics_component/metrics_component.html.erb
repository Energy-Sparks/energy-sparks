<%= tag.div id: id, class: classes do %>
  <%= render Layout::GridComponent.new(
        id: 'energy-efficiency-cards',
        cols: 2,
        classes: 'mb-4',
        cell_classes: 'mb-4',
        component_classes: 'theme theme-dark'
      ) do |grid| %>
    <% displayable.each do |metric| %>
      <% grid.with_stats_card(if: metric.energy_efficiency_type == :annual_saving) do |card| %>
        <%= card.with_header title: impact_t("energy_efficiency.metric_types.#{metric.metric_type}.title",
                                             fuel_type: t("advice_pages.fuel_type.#{metric.fuel_type}")) %>
        <%= card.with_figure format_unit(metric.value, metric.unit.to_sym, false) %>
        <%= card.with_subtext do
              impact_t("energy_efficiency.metric_types.#{metric.metric_type}.subtext",
                       count: metric.number_of_schools,
                       fuel_type: t("advice_pages.fuel_type.#{metric.fuel_type}"))
            end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
