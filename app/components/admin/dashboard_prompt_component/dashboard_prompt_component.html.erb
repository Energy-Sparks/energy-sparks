<%= tag.div id: id, class: classes do %>
  <%= render PromptListComponent.new do |list| %>
    <% if title? %>
      <% list.with_title(level: 2) do %>
        <%= title %>
      <% end %>
    <% end %>

    <% add_prompt(id: 'issues_for_review',
                  check: prompt_for_issues_review?,
                  list: list,
                  status: :negative,
                  icon: 'nocon') do %>
      <% issues_count %>
    <% end %>
  <% end %>
<% end %>
