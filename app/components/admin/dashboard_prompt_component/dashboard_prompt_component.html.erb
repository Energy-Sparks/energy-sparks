<%= tag.div id: id, class: classes do %>
  <%= render PromptListComponent.new do |list| %>
    <% if title? %>
      <% list.with_title(level: 2) do %>
        <%= title %>
      <% end %>
    <% end %>

    <% add_prompt(id: 'issues_for_renewal',
                  check: prompt_for_issues_renewal?,
                  list: list,
                  status: :negative,
                  icon: 'nocon') do %>
      <% 'isues due for renewal here' %>
    <% end %>
  <% end %>
<% end %>
