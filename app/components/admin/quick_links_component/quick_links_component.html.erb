<%= tag.div id: id, class: class_names(classes, 'mt-1') do %>
  <%= render Layout::GridComponent.new(cols: 2,
                                       component_classes: 'h-100 p-4 rounded-lg',
                                       cell_classes: 'mb-4') do |grid| %>
    <% grid.with_feature_card(theme: :pale) do |feature| %>
      <%= feature.with_description { 'Choose Group' } %>
      <%= feature.with_block(classes: 'mb-1') do %>
        <%= form_with url: admin_school_group_path(:school_group), method: :get, local: true,
                      class: 'd-flex align-items-center justify-content-end' do |form| %>
          <%= form.select :school_group, options_for_select(school_groups.pluck(:name, :slug)),
                          { prompt: 'select' }, class: 'form-control select2' %>
          <%= form.submit 'Manage', class: 'btn btn-primary ml-2' %>
        <% end %>
      <% end %>
    <% end %>
    <% grid.with_feature_card(theme: :pale) do |feature| %>
      <%= feature.with_description { 'Find MPXN' } %>
      <%= feature.with_block(classes: 'mb-1') do %>
        <%= form_with url: admin_schools_search_find_school_by_mpxn_index_path(:query), method: :get, local: true,
                      class: 'd-flex align-items-center justify-content-end' do |form| %>
          <%= form.search_field :query, class: 'form-control' %>
          <%= form.submit 'Submit', class: 'btn btn-primary ml-2' %>
        <% end %>
      <% end %>
    <% end %>
    <% grid.with_feature_card(theme: :pale) do |feature| %>
      <%= feature.with_description { 'Choose School' } %>
      <%= feature.with_block(classes: 'mb-1') do %>
        <%= form_with url: admin_school_path(:school), method: :get, local: true,
                      class: 'd-flex align-items-center justify-content-end' do |form| %>
          <%= form.select :school, options_for_select(schools.pluck(:name)),
                          { prompt: 'select' }, class: 'form-control select2' %>
          <%= form.submit 'Manage', class: 'btn btn-primary ml-2' %>
        <% end %>
      <% end %>
    <% end %>
    <% grid.with_feature_card(theme: :pale) do |feature| %>
      <%= feature.with_description { 'Find URN' } %>
      <%= feature.with_block(classes: 'mb-1') do %>
        <%= form_with url: admin_schools_search_find_school_by_urn_index_path(:query), method: :get, local: true,
                      class: 'd-flex align-items-center justify-content-end' do |form| %>
          <%= form.search_field :query, class: 'form-control' %>
          <%= form.submit 'Submit', class: 'btn btn-primary ml-2' %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
