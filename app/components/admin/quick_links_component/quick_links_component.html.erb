<%= tag.div id: id, class: class_names(classes, 'mt-1') do %>
  <%= render Layout::GridComponent.new(cols: 2,
                                       component_classes: 'h-100 p-4 rounded-lg',
                                       cell_classes: 'mb-4') do |grid| %>
    <% grid.with_feature_card(theme: :pale) do |feature| %>
      <%= feature.with_description { 'Select School Group' } %>
      <%= feature.with_block(classes: 'mb-1') do %>
        <%= form_with url: admin_dashboard_path(@user), method: :get, local: true,
                      class: 'd-flex align-items-center justify-content-end' do %>
          <%= select_tag :school_group_id,
                         options_from_collection_for_select(school_groups.by_name, :id, :name),
                         include_blank: 'select',
                         class: 'form-control select2' %>
          <%= submit_tag 'Manage', class: 'btn btn-primary ml-2' %>
        <% end %>
      <% end %>
    <% end %>
    <% grid.with_feature_card(theme: :pale) do |feature| %>
      <%= feature.with_description { 'Find MPXN' } %>
      <%= feature.with_block(classes: 'mb-1') do %>
        <%= form_with url: admin_find_school_by_mpxn_index_path, method: :get, local: true,
                      class: 'd-flex align-items-center justify-content-end' do |form| %>
          <%= form.search_field :query, class: 'form-control' %>
          <%= form.submit 'Submit', class: 'btn btn-primary ml-2' %>
        <% end %>
      <% end %>
    <% end %>
    <% grid.with_feature_card(theme: :pale) do |feature| %>
      <%= feature.with_description { 'Select School' } %>
      <%= feature.with_block(classes: 'mb-1') do %>
        <%= form_with url: admin_dashboard_path(@user), method: :get, local: true,
                      class: 'd-flex align-items-center justify-content-end' do %>
          <%= select_tag :school_id,
                         options_from_collection_for_select(schools.by_name, :id, :name),
                         include_blank: 'select',
                         class: 'form-control select2' %>
          <%= submit_tag 'Manage', class: 'btn btn-primary ml-2' %>
        <% end %>
      <% end %>
    <% end %>
    <% grid.with_feature_card(theme: :pale) do |feature| %>
      <%= feature.with_description { 'Find URN' } %>
      <%= feature.with_block(classes: 'mb-1') do %>
        <%= form_with url: admin_find_school_by_urn_index_path, method: :get, local: true,
                      class: 'd-flex align-items-center justify-content-end' do |form| %>
          <%= form.search_field :query, class: 'form-control' %>
          <%= form.submit 'Submit', class: 'btn btn-primary ml-2' %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
