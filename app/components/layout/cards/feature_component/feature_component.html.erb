<%= tag.div id: id, class: classes do %>
  <% if render_tags?(:top) %>
    <div class='pb-2'>
      <%= render_tags %>
    </div>
  <% end %>
  <%= header %>
  <%= price if price %>
  <% if date || datetime || author %>
    <div class='pb-3 small text-complement'>
      <%= date || datetime %>
      <% if author %>
        <%= t('common.author_html', author: author.to_s.html_safe) %>
      <% end %>
    </div>
  <% end %>
  <%= description if description %>
  <% blocks.each do |block| %>
    <%= block if block %>
  <% end %>
  <% if buttons.any? %>
    <div class='d-flex'>
      <% buttons.each do |button| %>
        <%= button %>
      <% end %>
    </div>
  <% end %>
  <% links.each do |link| %>
    <%= link %>
  <% end %>
  <% if render_tags?(:bottom) %>
    <div class='pb-2 mt-auto'>
      <%= render_tags %>
    </div>
  <% end %>
  <%= placeholder %>
<% end %>
